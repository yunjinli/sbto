    <!-- right ring -->
    <pair name="R_ring_prox_floor"  geom1="R_ring_prox_col"  geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>
    <pair name="R_ring_inter_floor" geom1="R_ring_inter_col" geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>

    <!-- right pinky -->
    <pair name="R_pinky_prox_floor"  geom1="R_pinky_prox_col"  geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>
    <pair name="R_pinky_inter_floor" geom1="R_pinky_inter_col" geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>

    <!-- ── Palm vs floor ─────────────────────────────────────────────────── -->
    <pair name="left_hand_floor"  geom1="left_hand_collision"  geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>
    <pair name="right_hand_floor" geom1="right_hand_collision" geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>

  </contact>

</mujoco>
