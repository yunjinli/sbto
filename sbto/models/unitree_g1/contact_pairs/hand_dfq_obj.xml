    <pair name="R_pinky_inter_obj" geom1="R_pinky_inter_col" geom2="obj" solref="0.01 1." friction="1 1" condim="3"/>

    <!-- ── All finger phalanges vs floor ───────────────────────────────────── -->

    <!-- left thumb -->
    <pair name="L_thumb_base_floor"  geom1="L_thumb_base_col"  geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>
    <pair name="L_thumb_prox_floor"  geom1="L_thumb_prox_col"  geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>
    <pair name="L_thumb_inter_floor" geom1="L_thumb_inter_col" geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>
