    <pair name="L_pinky_prox_floor"  geom1="L_pinky_prox_col"  geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>
    <pair name="L_pinky_inter_floor" geom1="L_pinky_inter_col" geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>

    <!-- right thumb -->
    <pair name="R_thumb_base_floor"  geom1="R_thumb_base_col"  geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>
    <pair name="R_thumb_prox_floor"  geom1="R_thumb_prox_col"  geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>
    <pair name="R_thumb_inter_floor" geom1="R_thumb_inter_col" geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>
    <pair name="R_thumb_dist_floor"  geom1="R_thumb_dist_col"  geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>

    <!-- right index -->
    <pair name="R_index_prox_floor"  geom1="R_index_prox_col"  geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>
    <pair name="R_index_inter_floor" geom1="R_index_inter_col" geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>

