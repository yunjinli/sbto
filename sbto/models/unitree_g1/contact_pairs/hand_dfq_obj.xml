<mujoco>

  <contact>
    <!-- ── Finger phalanges vs object ──────────────────────────────────────── -->
    <!-- solref="0.01 1." matches the original robot_obj.xml hand-obj style     -->
    <!-- (soft contacts, some penetration is accepted, consistent with pipeline) -->

    <!-- left thumb -->
    <pair name="L_thumb_base_obj"  geom1="L_thumb_base_col"  geom2="obj" solref="0.01 1." friction="1 1" condim="3"/>
    <pair name="L_thumb_prox_obj"  geom1="L_thumb_prox_col"  geom2="obj" solref="0.01 1." friction="1 1" condim="3"/>
    <pair name="L_thumb_inter_obj" geom1="L_thumb_inter_col" geom2="obj" solref="0.01 1." friction="1 1" condim="3"/>
    <pair name="L_thumb_dist_obj"  geom1="L_thumb_dist_col"  geom2="obj" solref="0.01 1." friction="1 1" condim="3"/>

    <!-- left index -->
    <pair name="L_index_prox_obj"  geom1="L_index_prox_col"  geom2="obj" solref="0.01 1." friction="1 1" condim="3"/>
    <pair name="L_index_inter_obj" geom1="L_index_inter_col" geom2="obj" solref="0.01 1." friction="1 1" condim="3"/>

    <!-- left middle -->
    <pair name="L_middle_prox_obj"  geom1="L_middle_prox_col"  geom2="obj" solref="0.01 1." friction="1 1" condim="3"/>
    <pair name="L_middle_inter_obj" geom1="L_middle_inter_col" geom2="obj" solref="0.01 1." friction="1 1" condim="3"/>

    <!-- left ring -->
