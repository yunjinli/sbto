    <pair name="R_thumb_dist_obj"  geom1="R_thumb_dist_col"  geom2="obj" solref="0.01 1." friction="1 1" condim="3"/>

    <!-- right index -->
    <pair name="R_index_prox_obj"  geom1="R_index_prox_col"  geom2="obj" solref="0.01 1." friction="1 1" condim="3"/>
    <pair name="R_index_inter_obj" geom1="R_index_inter_col" geom2="obj" solref="0.01 1." friction="1 1" condim="3"/>

    <!-- right middle -->
    <pair name="R_middle_prox_obj"  geom1="R_middle_prox_col"  geom2="obj" solref="0.01 1." friction="1 1" condim="3"/>
    <pair name="R_middle_inter_obj" geom1="R_middle_inter_col" geom2="obj" solref="0.01 1." friction="1 1" condim="3"/>

    <!-- right ring -->
