    <!-- left middle -->
    <pair name="L_middle_prox_floor"  geom1="L_middle_prox_col"  geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>
    <pair name="L_middle_inter_floor" geom1="L_middle_inter_col" geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>

    <!-- left ring -->
    <pair name="L_ring_prox_floor"  geom1="L_ring_prox_col"  geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>
    <pair name="L_ring_inter_floor" geom1="L_ring_inter_col" geom2="floor" condim="3" friction="0.8 0.005 0.0001"/>

