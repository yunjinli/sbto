    <pair name="L_pinky_inter_obj" geom1="L_pinky_inter_col" geom2="obj" solref="0.01 1." friction="1 1" condim="3"/>

    <!-- right thumb -->
    <pair name="R_thumb_base_obj"  geom1="R_thumb_base_col"  geom2="obj" solref="0.01 1." friction="1 1" condim="3"/>
    <pair name="R_thumb_prox_obj"  geom1="R_thumb_prox_col"  geom2="obj" solref="0.01 1." friction="1 1" condim="3"/>
