<mujoco model="g1_scene">
  <include file="g1_mjx_box_table.xml"/>

  <statistic center="0.0 0.0 0.5" extent="1.5"/>

  <!-- Default settings for materials and collision behavior -->
  <default>
    <default class="box_main">
      <default class="box_visual">
        <geom material="largebox_visualgeom" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="box_collision">
        <geom material="largebox_collision_material"
              condim="3"
              contype="1"
              conaffinity="1"/>
      </default>
    </default>
  </default>

  <!-- Lighting and rendering -->
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0.9 0.9 0.9"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="140" elevation="-20" offwidth="1920" offheight="1080"/>
  </visual>

  <!-- Assets: textures and materials -->
  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
             markrgb="0.8 0.8 0.8" width="300" height="300"/>

    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="largebox_visualgeom" rgba="0.7 0.7 0.7 1"/>
    <material name="largebox_collision_material" rgba="1.0 0.28 0.1 0.9"/>
    <material name="table_mat" rgba="0.6 0.5 0.4 1"/>
  </asset>

  <worldbody>
    <!-- Floor -->
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Static table (top at z = 0.7, thickness = 0.04 total) -->
    <body name="table" pos="0 0 0">
      <geom name="table_top"
            type="box"
            size="0.4 0.8 0.02"
            pos="0.6 0 0.68"
            mass="20"
            material="table_mat"
            contype="1" conaffinity="1"/>
    </body>

    <!-- Movable box (now placed in contact with the table) -->
    <!-- Box size = (0.1, 0.1, 0.115) so height = 0.23 -->
    <!-- Table surface = 0.70 => box center must be 0.70 + 0.115 = 0.815 -->
    <body name="largebox" pos="0.3 0 1.3" quat="1 0 0 0">
      <freejoint name="largebox_floating_base"/>

      <inertial mass="0.6" diaginertia="0.002 0.002 0.002" pos="0 0 0"/>

      <!-- Collision geometry -->
      <geom name="largebox_collision"
            type="box"
            size="0.1 0.1 0.115"
            class="box_collision"
            friction="0.6 0.005 0.0001"/>

      <!-- Visual geometry -->
      <geom name="largebox_visual"
            type="box"
            size="0.1 0.1 0.115"
            class="box_visual"
            material="largebox_visualgeom"/>

      <site name="largebox_site" pos="0 0 0" size="0.01" rgba="0 0 1 1"/>
    </body>
  </worldbody>

  <keyframe>

        <key name="home"
        qpos="
        -1.37702235e-01 -2.41068217e-02  7.67781351e-01  9.87731751e-01
          2.10662616e-05  1.51534236e-01  3.77274933e-02 -5.90415351e-01
          1.33497503e-01  9.12531617e-02  3.47689264e-01 -7.90546016e-02
        -1.53916729e-02 -6.19383677e-01 -1.50923154e-01 -7.99870610e-02
          3.57477582e-01 -8.35989993e-02  4.88744981e-02 -5.32730979e-02
        -8.67589353e-02  5.20000000e-01 -1.94149663e+00  5.25650919e-01
        -1.92168774e+00  1.26554972e+00  1.12513163e+00  5.52226629e-01
          1.42368975e+00 -1.84600818e+00 -4.88406039e-01  1.87607993e+00
          1.30359304e+00 -9.51898249e-01  6.44319872e-01 -1.45721787e+00
          4.00000000e-01  0.00000000e+00  8.15000000e-01  1.00000000e+00
          0.00000000e+00  0.00000000e+00  0.00000000e+00
        "
        ctrl="
        -5.90415351e-01  1.33497503e-01  9.12531617e-02  3.47689264e-01 -7.90546016e-02
        -1.53916729e-02 -6.19383677e-01 -1.50923154e-01 -7.99870610e-02
          3.57477582e-01 -8.35989993e-02  4.88744981e-02 -5.32730979e-02
        -8.67589353e-02  5.20000000e-01 -1.94149663e+00  5.25650919e-01
        -1.92168774e+00  1.26554972e+00  1.12513163e+00  5.52226629e-01
          1.42368975e+00 -1.84600818e+00 -4.88406039e-01  1.87607993e+00
          1.30359304e+00 -9.51898249e-01  6.44319872e-01 -1.45721787e+00
        "/>
  </keyframe>

</mujoco>
