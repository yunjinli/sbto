<mujoco>
    <sensor>
        <!-- actuator torques -->
        <actuatorfrc name="left_hip_pitch_joint" actuator="left_hip_pitch_joint"/>
        <actuatorfrc name="left_hip_roll_joint" actuator="left_hip_roll_joint"/>
        <actuatorfrc name="left_hip_yaw_joint" actuator="left_hip_yaw_joint"/>
        <actuatorfrc name="left_knee_joint" actuator="left_knee_joint"/>
        <actuatorfrc name="left_ankle_pitch_joint" actuator="left_ankle_pitch_joint"/>
        <actuatorfrc name="left_ankle_roll_joint" actuator="left_ankle_roll_joint"/>
        <actuatorfrc name="right_hip_pitch_joint" actuator="right_hip_pitch_joint"/>
        <actuatorfrc name="right_hip_roll_joint" actuator="right_hip_roll_joint"/>
        <actuatorfrc name="right_hip_yaw_joint" actuator="right_hip_yaw_joint"/>
        <actuatorfrc name="right_knee_joint" actuator="right_knee_joint"/>
        <actuatorfrc name="right_ankle_pitch_joint" actuator="right_ankle_pitch_joint"/>
        <actuatorfrc name="right_ankle_roll_joint" actuator="right_ankle_roll_joint"/>
        <actuatorfrc name="waist_yaw_joint" actuator="waist_yaw_joint"/>
        <actuatorfrc name="left_shoulder_pitch_joint" actuator="left_shoulder_pitch_joint"/>
        <actuatorfrc name="left_shoulder_roll_joint" actuator="left_shoulder_roll_joint"/>
        <actuatorfrc name="left_shoulder_yaw_joint" actuator="left_shoulder_yaw_joint"/>
        <actuatorfrc name="left_elbow_joint" actuator="left_elbow_joint"/>
        <actuatorfrc name="left_wrist_roll_joint" actuator="left_wrist_roll_joint"/>
        <actuatorfrc name="right_shoulder_pitch_joint" actuator="right_shoulder_pitch_joint"/>
        <actuatorfrc name="right_shoulder_roll_joint" actuator="right_shoulder_roll_joint"/>
        <actuatorfrc name="right_shoulder_yaw_joint" actuator="right_shoulder_yaw_joint"/>
        <actuatorfrc name="right_elbow_joint" actuator="right_elbow_joint"/>
        <actuatorfrc name="right_wrist_roll_joint" actuator="right_wrist_roll_joint"/>

        <!-- feet contact -->
        <contact geom1="floor" geom2="left_foot1_collision" reduce="maxforce" data="found force" num="1" name="left_foot1"/>
        <contact geom1="floor" geom2="left_foot2_collision" reduce="maxforce" data="found force" num="1" name="left_foot2"/>
        <contact geom1="floor" geom2="left_foot3_collision" reduce="maxforce" data="found force" num="1" name="left_foot3"/>
        <contact geom1="floor" geom2="right_foot1_collision" reduce="maxforce" data="found force" num="1" name="right_foot1"/>
        <contact geom1="floor" geom2="right_foot2_collision" reduce="maxforce" data="found force" num="1" name="right_foot2"/>
        <contact geom1="floor" geom2="right_foot3_collision" reduce="maxforce" data="found force" num="1" name="right_foot3"/>

        <!-- feet pos and vel -->
        <!--         
        <framepos objtype="site" objname="right_foot" name="right_foot_pos"/>
        <framepos objtype="site" objname="left_foot" name="left_foot_pos"/>
        <framelinvel objtype="site" objname="right_foot" name="right_foot_vel"/>
        <framelinvel objtype="site" objname="left_foot" name="left_foot_vel"/>
         -->
        <!-- pelvis + torso pos and vel -->
        <framepos objtype="site" objname="imu_in_torso" name="global_pos_torso"/>
        <!-- <framepos objtype="site" objname="imu_in_pelvis" name="global_pos_pelvis"/> -->
        <framelinvel objtype="site" objname="imu_in_torso" name="global_linvel_torso"/>
        <!-- <framelinvel objtype="site" objname="imu_in_pelvis" name="global_linvel_pelvis"/> -->
        <frameangvel objtype="site" objname="imu_in_torso" name="global_angvel_torso"/>
        <!-- <frameangvel objtype="site" objname="imu_in_pelvis" name="global_angvel_pelvis"/> -->

        <!-- pelvis + torso upright and orientation -->
        <framezaxis objtype="site" objname="imu_in_torso" name="upvector_torso"/>
        <!-- <framezaxis objtype="site" objname="imu_in_pelvis" name="upvector_pelvis"/> -->
        <framequat objtype="site" objname="imu_in_torso" name="orientation_torso"/>
        <!-- <framequat objtype="site" objname="imu_in_pelvis" name="orientation_pelvis"/> -->

    </sensor>
</mujoco>